# Same Web client ID as backend GOOGLE_CLIENT_ID (Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Local dev: leave unset — Vite proxies /api to http://localhost:8080 (vite.config.js).
# Production: set in Vercel Dashboard → Project → Settings → Environment Variables
VITE_API_URL=https://placetopage-backend.vercel.app

# PayPal (same Client ID as backend PAYPAL_CLIENT_ID — public in the browser)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

# Hero image uploads use the API only — no GCP keys in the browser (see backend/.env.example).
